#!/bin/bash

# omarchy:summary=Set the current background image
# omarchy:args=<path-to-image>
# omarchy:examples=omarchy theme bg set ~/Pictures/background.png

if [[ -z $1 ]]; then
  echo "Usage: omarchy-theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND="$(realpath "$1")"
CURRENT_BACKGROUND_LINK="$HOME/.config/omarchy/current/background"

if [[ ! -f "$BACKGROUND" ]]; then
  echo "File does not exist: $BACKGROUND" >&2
  exit 1
fi

# Create symlink to the new background
ln -nsf "$BACKGROUND" "$CURRENT_BACKGROUND_LINK"

# Keep the Quickshell ii background in sync with Omarchy's wallpaper picker.
QUICKSHELL_CONFIG="$HOME/.config/quickshell/config.json"
if [[ -f $QUICKSHELL_CONFIG ]] && command -v jq >/dev/null 2>&1; then
  tmp="$(mktemp)"
  jq --arg path "$BACKGROUND" '.background.wallpaperPath = $path | .background.thumbnailPath = ""' "$QUICKSHELL_CONFIG" >"$tmp" &&
    mv "$tmp" "$QUICKSHELL_CONFIG"
  rm -f "$tmp"
fi

# Kill existing swaybg and start new one
pkill -x swaybg
setsid uwsm-app -- swaybg -i "$CURRENT_BACKGROUND_LINK" -m fill >/dev/null 2>&1 &
