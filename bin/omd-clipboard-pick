#!/bin/sh
# Launch walker clipboard picker; auto-paste selection into focused window.
set -eu

selection=$(walker -m clipboard -t omd --width 720 --maxheight 400 \
    -p "Search clipboard history..." </dev/null 2>/dev/null) || true

if [ -z "$selection" ]; then
    exit 0
fi

# cliphist list lines are "<id>\t<content>"; decode restores the full content.
printf '%s\n' "$selection" | cliphist decode | wl-copy

# Small delay so the clipboard is updated before we paste.
sleep 0.05

# Simulate Ctrl+V in the previously focused window.
wtype -M ctrl -k v -m ctrl