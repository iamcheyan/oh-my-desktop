#!/bin/sh
# Launch walker clipboard picker; auto-paste selection into focused window.
# dmenu mode: cliphist list piped to stdin, selection output to stdout.
# Prepends type icons (📝 text / 🖼 image) for visual distinction.

selection=$(cliphist list | sed \
    -e 's/^[0-9]*\t\[\[ binary data/🖼 [[ binary data/' \
    -e 's/^[0-9]*\t\(.*\)/📝 \1/' | \
    walker --dmenu --width 720 --maxheight 400 \
    -p "Search clipboard history..." 2>/dev/null) || true

if [ -z "$selection" ]; then
    exit 0
fi

# Strip icon prefix, then find the matching original cliphist line.
content=$(printf '%s\n' "$selection" | sed 's/^[📝🖼] //')
orig=$(cliphist list | grep -F	"$content" | head -1)

if [ -n "$orig" ]; then
    printf '%s\n' "$orig" | cliphist decode | wl-copy
    sleep 0.05
    wtype -M ctrl -k v -m ctrl
fi