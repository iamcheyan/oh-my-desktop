#!/bin/sh
# Launch walker clipboard picker; auto-paste selection into focused window.
# dmenu mode: cliphist list piped to stdin, selection output to stdout.
# Image entries get an icon prefix for visual distinction.

selection=$(cliphist list | sed 's/^\([0-9]*\)\t\[\[ binary data/\1\t🖼 /' | \
    walker --dmenu --width 720 --maxheight 400 \
    -p "Search clipboard history..." 2>/dev/null) || true

if [ -z "$selection" ]; then
    exit 0
fi

# Remove the icon prefix if present, then decode.
printf '%s\n' "$selection" | sed 's/^\([0-9]*\)\t🖼 /\1\t[[ binary data/' | \
    cliphist decode | wl-copy

sleep 0.05
wtype -M ctrl -k v -m ctrl