#!/bin/sh
# Launch walker clipboard picker; auto-paste selection into focused window.
# dmenu mode: cliphist list piped to stdin, selection output to stdout.
# Prepends type icons (📝 text / 🖼 image) before the ID for visual distinction.

selection=$(cliphist list | sed \
    -e 's/^\([0-9]*\)\t\[\[ binary data/🖼 \1\t[[ binary data/' \
    -e 's/^\([0-9]*\)\t\(.*\)/📝 \1\t\2/' | \
    walker --dmenu --width 720 --maxheight 400 \
    -p "Search clipboard history..." 2>/dev/null) || true

if [ -z "$selection" ]; then
    exit 0
fi

# Strip the icon prefix to recover the original cliphist line.
printf '%s\n' "$selection" | sed 's/^[📝🖼] //' | cliphist decode | wl-copy

sleep 0.05
wtype -M ctrl -k v -m ctrl