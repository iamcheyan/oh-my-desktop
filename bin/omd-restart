#!/bin/sh
set -eu

# Kill ALL quickshell processes (split apps + monolith + stray)
pkill -f "(quickshell|qs) -p " 2>/dev/null || true
pkill -f "wl-paste --watch.*cliphist" 2>/dev/null || true
# Wait for processes to die
sleep 0.3
# Hard kill any survivors
pkill -9 -f "(quickshell|qs) -p " 2>/dev/null || true

start_app() {
    app="$1"
    if command -v systemd-run >/dev/null 2>&1 && systemctl --user is-active default.target >/dev/null 2>&1; then
        systemctl --user stop "$app.service" >/dev/null 2>&1 || true
        systemctl --user reset-failed "$app.service" >/dev/null 2>&1 || true
        rm -f "/run/user/$(id -u)/systemd/transient/$app.service" 2>/dev/null || true
        systemctl --user daemon-reload >/dev/null 2>&1 || true
        # KillMode=process: only kill the main shell process, NOT child processes.
        # Quickshell launches apps (Firefox, etc.) via execDetached — those become
        # children of the quickshell process. control-group (the default) would
        # kill them too, destroying apps on other workspaces during reload.
        # The pkill above handles killing the actual quickshell binary.
        # DO NOT change to control-group — it will kill user apps on reload.
        systemd-run --user --unit="$app" --collect \
            --property=KillMode=process \
            /bin/sh -c "exec \"\$HOME/.config/omd/bin/$app\" >/tmp/$app.log 2>&1" >/dev/null
    else
        setsid "$HOME/.config/omd/bin/$app" >/tmp/$app.log 2>&1 < /dev/null &
    fi
}

start_app omd-bar
start_app omd-desktop
start_app omd-overview
start_app omd-switcher
start_app omd-applauncher
start_app omd-corners
start_app omd-clipboard
start_app omd-clipboard-store
