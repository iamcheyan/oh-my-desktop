#!/usr/bin/env bash
set -euo pipefail

OMARCHY_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/omarchy"
OMARCHY_SHARE="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
CURRENT_NAME_FILE="$OMARCHY_CONFIG/current/theme.name"

slug_to_title() {
  sed -E 's/(^|-)([a-z])/\1\u\2/g; s/-/ /g' <<<"$1"
}

theme_preview() {
  # Theme previews are generated from colors.toml in Settings Center. Keep this
  # field empty for backwards-compatible tab-separated output.
  printf '\n'
}

theme_color() {
  local slug="$1"
  local key="$2"
  local base=""

  if [[ -d "$OMARCHY_CONFIG/themes/$slug" ]]; then
    base="$OMARCHY_CONFIG/themes/$slug"
  elif [[ -d "$OMARCHY_SHARE/themes/$slug" ]]; then
    base="$OMARCHY_SHARE/themes/$slug"
  fi

  if [[ -n "$base" && -f "$base/colors.toml" ]]; then
    awk -F= -v key="$key" '
      $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
        value = $2
        gsub(/[[:space:]"\047]/, "", value)
        print value
        exit
      }
    ' "$base/colors.toml"
    return
  fi

  printf '\n'
}

list_themes() {
  local current
  current="$(cat "$CURRENT_NAME_FILE" 2>/dev/null || true)"

  {
    find "$OMARCHY_CONFIG/themes" -mindepth 1 -maxdepth 1 \( -type d -o -type l \) -printf '%f\n' 2>/dev/null || true
    find "$OMARCHY_SHARE/themes" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' 2>/dev/null || true
  } | sort -u | while IFS= read -r slug; do
    [[ -n "$slug" ]] || continue
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$slug" \
      "$(slug_to_title "$slug")" \
      "$(theme_preview "$slug")" \
      "$([[ "$slug" == "$current" ]] && printf current || printf available)" \
      "$(theme_color "$slug" accent)" \
      "$(theme_color "$slug" background)" \
      "$(theme_color "$slug" foreground)"
  done
}

current_theme() {
  local current
  current="$(cat "$CURRENT_NAME_FILE" 2>/dev/null || true)"
  if [[ -n "$current" ]]; then
    printf 'slug=%s\nname=%s\npreview=%s\naccent=%s\nbackground=%s\nforeground=%s\n' \
      "$current" \
      "$(slug_to_title "$current")" \
      "$(theme_preview "$current")" \
      "$(theme_color "$current" accent)" \
      "$(theme_color "$current" background)" \
      "$(theme_color "$current" foreground)"
  else
    printf 'slug=\nname=Unknown\npreview=\naccent=\nbackground=\nforeground=\n'
  fi
}

apply_theme() {
  local slug="${1:-}"
  [[ -n "$slug" ]] || { echo "usage: omd-settings-theme apply <theme-slug>" >&2; exit 2; }

  OMARCHY_THEME_SKIP_BACKGROUND=1 omarchy-theme-set "$slug"
}

case "${1:-list}" in
  list) list_themes ;;
  current) current_theme ;;
  apply) apply_theme "${2:-}" ;;
  *)
    echo "usage: omd-settings-theme list|current|apply <theme-slug>" >&2
    exit 2
    ;;
esac
