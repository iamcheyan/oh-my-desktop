#!/bin/sh
set -eu

omd_root="${OMD_ROOT:-$HOME/.config/omd}"

stop_quickshell() {
    for app in omd-bar omd-overview omd-switcher omd-applauncher omd-corners omd-clipboard omd-clipboard-store; do
        systemctl --user stop "$app.service" >/dev/null 2>&1 || true
        pkill -f "quickshell.* -p $omd_root/apps/$app($| )" || true
    done
    pkill -f "wl-paste --watch cliphist store" || true
}

stop_waybar() {
    pkill -x waybar 2>/dev/null || true
}

start_quickshell() {
    if [ -x "$omd_root/bin/omd-restart" ]; then
        "$omd_root/bin/omd-restart"
    else
        printf 'No Quickshell launcher found at %s/bin/omd-restart\n' "$omd_root" >&2
        exit 1
    fi
}

stop_quickshell
stop_waybar
start_quickshell

sleep 1
pgrep -af 'quickshell|qs -p' || true
