#!/bin/sh
set -eu

omd_root="${OMD_ROOT:-$HOME/.config/omd}"
legacy_root="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell"

stop_quickshell() {
    if command -v systemctl >/dev/null 2>&1 && systemctl --user is-active default.target >/dev/null 2>&1; then
        systemctl --user stop omd-bar.service >/dev/null 2>&1 || true
        systemctl --user stop omd-overview.service >/dev/null 2>&1 || true
        systemctl --user stop omd-switcher.service >/dev/null 2>&1 || true
    fi

    pkill -f "quickshell.* -p $omd_root/apps/omd-bar($| )" || true
    pkill -f "quickshell.* -p $omd_root/apps/omd-overview($| )" || true
    pkill -f "quickshell.* -p $omd_root/apps/omd-switcher($| )" || true
    pkill -f "quickshell.* -p $legacy_root($| )" || true
}

start_quickshell() {
    if [ -x "$omd_root/bin/omd-restart" ]; then
        "$omd_root/bin/omd-restart"
    elif [ -x "$legacy_root/scripts/quickshell" ]; then
        setsid "$legacy_root/scripts/quickshell" >/tmp/omd-quickshell.log 2>&1 < /dev/null &
    else
        printf 'No Quickshell launcher found.\n' >&2
        printf 'Checked: %s/bin/omd-restart\n' "$omd_root" >&2
        printf 'Checked: %s/scripts/quickshell\n' "$legacy_root" >&2
        exit 1
    fi
}

stop_quickshell
start_quickshell

sleep 1
pgrep -af 'quickshell|qs -p' || true
