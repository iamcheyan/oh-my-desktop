#!/bin/sh
set -eu

omd_root="${OMD_ROOT:-$HOME/.config/omd}"

stop_quickshell() {
    # Kill ALL quickshell processes: split apps + monolith + stray
    pkill -f "(quickshell|qs) -p " 2>/dev/null || true
    # Kill clipboard watcher
    pkill -f "wl-paste --watch.*cliphist" 2>/dev/null || true
    # Wait for processes to die
    sleep 0.3
    # Hard kill any survivors
    pkill -9 -f "(quickshell|qs) -p " 2>/dev/null || true
}

stop_waybar() {
    pkill -x waybar 2>/dev/null || true
}

start_quickshell() {
    if [ -x "$omd_root/bin/omd-restart" ]; then
        "$omd_root/bin/omd-restart"
    else
        printf 'No Quickshell launcher found at %s/bin/omd-restart\n' "$omd_root" >&2
        exit 1
    fi
}

stop_quickshell
stop_waybar
sleep 0.2
start_quickshell
omarchy-restart-walker

sleep 1
pgrep -af '(quickshell|qs|wl-paste)' || true
