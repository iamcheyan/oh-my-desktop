#!/bin/sh
set -eu

if [ "${1:-}" = "--run" ]; then
    tool_label="${2:-tool}"
    binary="${3:-}"

    if [ -z "$binary" ]; then
        printf 'Missing binary for %s\n' "$tool_label" >&2
        exit 2
    fi

    set +e
    "$binary"
    status=$?
    set -e

    if [ "$status" -ne 0 ]; then
        printf '\n%s exited with status %s.\n' "$tool_label" "$status" >&2
        printf 'Press Enter to close...' >&2
        read _ || true
    fi

    exit "$status"
fi

tool="${1:-}"

case "$tool" in
    wifi|wifitui)
        bin_name="wifitui"
        repo="shazow/wifitui"
        title="Wi-Fi"
        class="org.omd.wifitui"
        archive="tar.gz"
        ;;
    bluetooth|bluetui)
        bin_name="bluetui"
        repo="pythops/bluetui"
        title="BlueTUI"
        class="org.omd.bluetui"
        archive="raw"
        ;;
    *)
        printf 'Usage: %s wifi|bluetooth\n' "$0" >&2
        exit 2
        ;;
esac

install_dir="${OMD_TUI_BIN_DIR:-$HOME/.local/bin}"
mkdir -p "$install_dir"

arch="$(uname -m)"
case "$bin_name:$arch" in
    wifitui:aarch64|wifitui:arm64) asset_pattern="wifitui-*-linux-arm64.tar.gz" ;;
    wifitui:x86_64|wifitui:amd64) asset_pattern="wifitui-*-linux-x86_64.tar.gz" ;;
    bluetui:aarch64|bluetui:arm64) asset="bluetui-aarch64-linux-musl" ;;
    bluetui:x86_64|bluetui:amd64) asset="bluetui-x86_64-linux-musl" ;;
    *)
        printf 'Unsupported architecture for %s: %s\n' "$bin_name" "$arch" >&2
        exit 1
        ;;
esac

find_binary() {
    if command -v "$bin_name" >/dev/null 2>&1; then
        command -v "$bin_name"
        return 0
    fi

    if [ -x "$install_dir/$bin_name" ]; then
        printf '%s\n' "$install_dir/$bin_name"
        return 0
    fi

    return 1
}

shell_quote() {
    printf "'"
    printf '%s' "$1" | sed "s/'/'\\\\''/g"
    printf "'"
}

download_binary() {
    if ! command -v curl >/dev/null 2>&1; then
        printf 'curl is required to download %s\n' "$bin_name" >&2
        exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        printf 'jq is required to resolve GitHub release assets for %s\n' "$bin_name" >&2
        exit 1
    fi

    api_url="https://api.github.com/repos/$repo/releases/latest"
    download_url="$(
        curl -fsSL "$api_url" |
            jq -r --arg asset "${asset:-}" --arg pattern "${asset_pattern:-}" '
                .assets[]
                | select(
                    if $asset != "" then
                        .name == $asset
                    else
                        .name | test("^" + ($pattern | gsub("\\*"; ".*")) + "$")
                    end
                )
                | .browser_download_url
            ' |
            sed -n '1p'
    )"

    if [ -z "$download_url" ] || [ "$download_url" = "null" ]; then
        printf 'Could not find release asset for %s in %s\n' "$bin_name" "$api_url" >&2
        exit 1
    fi

    tmp="$(mktemp "${TMPDIR:-/tmp}/$bin_name.XXXXXX")"
    trap 'rm -f "$tmp"' EXIT
    curl -fsSL "$download_url" -o "$tmp"

    if [ "$archive" = "tar.gz" ]; then
        extract_dir="$(mktemp -d "${TMPDIR:-/tmp}/$bin_name.extract.XXXXXX")"
        trap 'rm -f "$tmp"; rm -rf "$extract_dir"' EXIT
        tar -xzf "$tmp" -C "$extract_dir" "$bin_name"
        chmod 0755 "$extract_dir/$bin_name"
        mv "$extract_dir/$bin_name" "$install_dir/$bin_name"
        rm -rf "$extract_dir"
    else
        chmod 0755 "$tmp"
        mv "$tmp" "$install_dir/$bin_name"
    fi
    trap - EXIT
}

binary="$(find_binary || true)"
if [ -z "$binary" ]; then
    download_binary
    binary="$(find_binary)"
fi

self="$(readlink -f "$0" 2>/dev/null || printf '%s\n' "$0")"
runner_cmd="$(shell_quote "$self") --run $(shell_quote "$bin_name") $(shell_quote "$binary")"

if command -v kitty >/dev/null 2>&1; then
    terminal_cmd="kitty --class $(shell_quote "$class") --title $(shell_quote "$title") -e $runner_cmd"
elif command -v alacritty >/dev/null 2>&1; then
    terminal_cmd="alacritty --class $(shell_quote "$class") -T $(shell_quote "$title") -e $runner_cmd"
else
    printf 'No supported terminal found. Install kitty or alacritty.\n' >&2
    exit 1
fi

if command -v hyprctl >/dev/null 2>&1; then
    if ! hyprctl dispatch "hl.dsp.exec_cmd([[$terminal_cmd]])" >/dev/null 2>&1; then
        if ! hyprctl dispatch exec -- "$terminal_cmd" >/dev/null 2>&1; then
            sh -c "exec $terminal_cmd" &
        fi
    fi
else
    sh -c "exec $terminal_cmd" &
fi
